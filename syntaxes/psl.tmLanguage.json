{
    "comment": "---",
    "comment": "Syntax highlighting for the Profile Scripting Language (PSL) and M.",
    "comment": "---",
    "comment": "The order of the includes and matches in the patterns is significant. On the contrary, the order of",
    "comment": "the repository entries is not: repository entries occur in alphabetic order.",
    "comment": "---",
    "comment": "SOLVED ISSUES [relative to the previous iteration]",
    "comment": "  1. A statement on a line with a non-numeric label (i.e., no formal-list) is classified as",
    "comment": "     'entity.name.function.psl'",
    "comment": "---",
    "comment": "KNOWN ISSUES",
    "comment": "  1. In SCMs, nth (n > 1) local subroutine/label occurrences in 'do' statements are classified as",
    "comment": "     'entity.name.unknown.psl'. [Adversity: only the last iteration of a repeated capturing group is",
    "comment": "     actually captured.]",
    "comment": "  2. Tokens are categorized as 'variable.other.psl' in contexts where they should be qualified as",
    "comment": "     'entity.name.unknown.psl'. [Bear in mind that the latter was deprecated in favor of the former in",
    "comment": "     the current iteration. The benefits of categorizing all currently unknown entities as variables",
    "comment": "     most certainly exceed its costs: most occurrences of unknown entities throughout PSL code actually",
    "comment": "     correspond to variables.]",
    "comment": "---",
    
    "name": "Profile Scripting Language",
    
    "scopeName": "source.psl",
    
    "patterns": [
        { 
          "include": "#comments",
          "comment": "PSL comment-block, PSL comment-to-end-of-line, and M comment-to-end-of-line."
        },
        { 
          "include": "#accept-directive",
          "comment": "#ACCEPT directive with all text following the directive considered comment."
        },
        { 
          "include": "#classdef-directive",
          "comment": "#CLASSDEF directive with putative qualifiers."
        },
        { 
          "include": "#if-directive",
          "comment": "#IF and #ELSEIF directives (followed by PSL code)."
        },
        { 
          "include": "#optimize-directive",
          "comment": "#OPTIMIZE code generator directive."
        },
        { 
          "include": "#option-directive",
          "comment": "#OPTION code generator directive."
        },
        { 
          "include": "#package-directive",
          "comment": "#PACKAGE directive with root-package and optional sub-packages."
        },
        { 
          "include": "#propertydef-directive",
          "comment": "#PROPERTYDEF directive with qualifiers and modifiers."
        },
        { 
          "include": "#warn-directive",
          "comment": "#INFO and #WARN code generator directives."
        },
        { 
          "include": "#other-directive",
          "comment": "#BYPASS, #ELSE, #END, #ENDBYPASS, and #ENDIF code generator directives."
        },
        { 
          "include": "#subroutine-declaration",
          "comment": "Subroutine declaration (note that it must precede '#method-declaration')."
        },
        { 
          "include": "#method-declaration",
          "comment": "Method declaration (including formal parameters)."
        },
        { 
          "include": "#label-declaration",
          "comment": "Label declaration (method declaration without formal-list)."
        },
        { 
          "include": "#statements",
          "comment": "PSL statements ('write', 'catch', 'do', 'if', etc.)."
        },
        { 
          "include": "#literals",
          "comment": "Numeric literals and string literals."
        },
        { 
          "include": "#special-constructs",
          "comment": "I.e., true/false, this/super, system keywords."
        },
        { 
          "include": "#operators",
          "comment": "Unary and binary operators."
        },
        { 
          "include": "#modifiers",
          "comment": "Storage and visibility modifiers (e.g., 'public', 'private', 'literal', 'readonly', etc.)"
        },
        { 
          "include": "#name-in-context",
          "comment": "E.g., class name, method name, property name, and variable name."
        }
    ],
    
    "repository": {
  
        "accept-directive": {
            "comment": "All text following the '#ACCEPT' directive is rendered as a comment.",
            "match": "^[ \t]+(#ACCEPT)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codegeneratorDirective.accept.psl"},
                "2": { "name": "comment.inline.psl"}
            }
        },
  
        "class-names": {
            "patterns": [
                { "include": "#psl-language-class"},
                { "name": "entity.name.class.psl",
                  "comment": "All other names that occur when a class name is expected.",
                  "match": "[%A-Za-z][A-Za-z0-9]*"}
            ]
        },
  
        "classdef-directive": {
            "match": "^[ \t]+(#CLASSDEF)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codegeneratorDirective.classdef.psl"},
                "2": {
                    "patterns": [
                        { "name": "keyword.other.classdef.psl", "match": "\\b(extends|delimiter)\\b"},
                        { "name": "storage.modifier.visibility.psl", "match": "\\b(public)\\b"},
                        { "include": "#class-names"},
                        { "include": "#operators"},
                        { "include": "#literals"}
                    ]
                }
            }
        },
  
        "comments": {
            "patterns": [
                { "include": "#comments-section-marker-block"},
                { "include": "#comments-section-marker"},
                { "include": "#comments-inline-m"},
                { "include": "#comments-inline-psl"},
                { "include": "#comments-psldoc",
                  "comment": "This rule must occur *before* the rule for a (standard) comment block."},
                { "include": "#comments-block"}
            ]
        },
  
        "comments-section-marker": {
            "name": "comment.batch.section",
            "match": "^-{10}[ \t]+(SCHINIT|SCHEXEC|SCHPOST|SCHEXIT|THRINIT|THREXEC|EXEC|THREXIT)[ \t]+-{6} Section marker[ \t]*$",
            "captures": {
                "0": { "name": "punctuation.definition.comment.psl"},
                "1": { "name": "entity.name.function.batch.psl"}
            }
        },
  
        "comments-section-marker-block": {
            "name": "comment.batch.section",
            "comment": "---",
            "comment": "1. It is assumed that every BATCH definition contains a REVHIST section immediately followed",
            "comment": "   by an OPEN section marker: the logic for including 'doc-params' [@created, @return, etc.]",
            "comment": "   highlighting under the REVLIST section depends on it.",
            "comment": "---",
            "begin": "^-{10}[ \t]+(REVHIST)[ \t]+-{6} Section marker[ \t]*$",
            "comment": "---",
            "comment": "2. If the literal '---------- OPEN ------ Section marker' is not found upon starting a REVHIST",
            "comment": "   section, the syntax highlighter assumes that everything that comes after the literal",
            "comment": "   '---------- REVHIST ------ Section marker' is 'comment.batch.section'.",
            "comment": "---",
            "end": "^-{10}[ \t]+(OPEN)[ \t]+-{6} Section marker[ \t]*$",
            "comment": "---",
            "comment": "3. Using the captures key for a begin/end rule is short-hand for giving both beginCaptures and",
            "comment": "   endCaptures with same values. [FROM https://macromates.com/manual/en/language_grammars]",
            "comment": "---",
            "captures": {
                "0": { "name": "punctuation.definition.comment.psl"},
                "1": { "name": "entity.name.function.batch.psl"}
            },
            "patterns": [
                { "include": "#doc-params"},
                { "include": "#todo"}
            ]
        },
        
        "comments-block": {
            "name": "comment.block.psl",
            "begin": "/\\*",
            "end": "\\*/",
            "captures": {
                "0": { "name": "punctuation.definition.comment.psl"}
            },
            "patterns": [
                { "include": "#doc-params"},
                { "include": "#todo"}
            ]
        },
        
        "comments-inline-m": {
            "name": "comment.line.semicolon.psl",
            "comment": "---",
            "comment": "1. Note that M-style comments are valid in PSL.",
            "comment": "2. Do 'doc-params' make any sense in this context [single-line comment]?",
            "comment": "---",
            "begin": ";",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.psl"}
            },
            "end": "\\n",
            "patterns": [
                { "include": "#doc-params"},
                { "include": "#todo"}
            ]
        },
  
        "comments-inline-psl": {
            "name": "comment.line.double-slash.psl",
            "comment": "---",
            "comment": "Does including 'doc-params' in the list of patterns to be matched make any sense in this",
            "comment": "context [single-line comment]?",
            "comment": "---",
            "begin": "//",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.psl"}
            },
            "end": "\\n",
            "patterns": [
                { "include": "#doc-params"},
                { "include": "#todo"}
            ]
        },
  
        "comments-psldoc": {
            "name": "comment.block.documentation.psl",
            "comment": "---",
            "comment": "1. Documentation blocks begin with 'DOC' and end with '** ENDDOC'.",
            "comment": "2. The 'DOC' block should also have a set of following dashes to create a clearly visible",
            "comment": "   break. While this is not required by the compiler to identify the documentation start, it",
            "comment": "   is required as part of the standard for readability.",
            "comment": "3. It is assumed that both 'DOC' and 'ENDDOC' should be delimited by either spaces or tabs.",
            "comment": "4. Is the existence of 'comments-psldoc' really beneficial in the context of syntax",
            "comment": "   highlighting? Although it provides an extra scope [maybe useful if inspecting editor tokens",
            "comment": "   and scopes?], it is still a subcategory of 'comments-block'.",
            "comment": "---",
            "begin": "/\\*[ \t]+DOC([ \t]*|[ \t]+-{0,})$",
            "end": "\\*\\*[ \t]+ENDDOC[ \t]+\\*/$",
            "captures": {
                "0": { "name": "punctuation.definition.comment.psl"}
            },
            "patterns": [
                { "include": "#comments-inline-m", "comment": "Is it really necessary?"},
                { "include": "#comments-inline-psl", "comment": "Is it really necessary?"},
                { "include": "#doc-params"},
                { "include": "#todo"}
            ]
        },
  
        "doc-params": {
            "patterns": [
                { "comment": "---",
                  "comment": "PSL DOC subsections with an identifier.",
                  "comment": "---",
                  "comment": "Visit the 'package-directive' subsection for the reasoning behing the optional group at",
                  "comment": "the end of the regex.",
                  "comment": "---",
                  "match": "^[ \t]*(@(args|param|publicnew|public|throws)\\b)([ \t]+([A-Za-z\\-0-9%_\\.]+)[ \t]*)?",
                  "captures": {
                      "1": { "name": "markup.heading.jsdoc", "comment": "The '@' character."},
                      "2": { "name": "markup.heading.jsdoc", "comment": "The PSL DOC subsection keyword."},
                      "4": { "name": "variable.other.jsdoc", "comment": "The variable or error ID."}
                  }
                },
                { "name": "markup.heading.jsdoc",
                  "comment": "PSL DOC subsections without an identifier.",
                  "match": "^[ \t]*@(created|return|when)\\b[ \t]*"}
            ]
        },
  
        "formal-parameter": {
            "name": "meta.function.formal-parameter.psl",
            "match": "\\s*((req[ \t]+ret|req[ \t]+noret|req|ret|noret)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)([ \t]*\\(([ \t]*([%A-Za-z][A-Za-z0-9]*)?\\,?)*\\))?",
            "captures": {
                "2": { "name": "storage.modifier.formal-argument.psl"},
                "3": { "patterns": [ { "include": "#class-names"}]},
                "4": { "name": "variable.parameter.psl"},
                "5": { "patterns": [ { "include": "#class-names"}]}
            }
        },
  
        "if-directive": {
            "comment": "PSL code generator directives that are followed by PSL code",
            "match": "^[ \t]+(#IF|#ELSEIF)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.psl"},
                "2": {
                    "patterns": [
                        { 
                          "include": "#comments-inline-m"
                        },
                        { 
                          "include": "#comments-inline-psl",
                          "comment": "---",
                          "comment": "Must be included prior to 'operators'; otherwise, the comment token [i.e., '//']",
                          "comment": "will be mistaken for two occurrences of the division operator [i.e., '/']. It",
                          "comment": "actually should be first on the list [as with 'comments-inline-m']: everything",
                          "comment": "to the right of a comment token is considered to be a comment.",
                          "comment": "---"
                        },
                        { 
                          "include": "#comments-block"
                        },
                        { 
                          "include": "#statements",
                          "comment": "---",
                          "comment": "Try statements prior to class names if the line contains labels and statements.",
                          "comment": "I.e., prioritize statements [the order of the 'includes' matters].",
                          "comment": "---"
                        },
                        { 
                          "include": "#literals",
                          "comment": "Numeric literals and string literals."
                        },
                        { 
                          "include": "#special-constructs",
                          "comment": "I.e., true/false, this/super, system keywords."
                        },
                        { 
                          "include": "#operators",
                          "comment": "Binary and unary operators."
                        },
                        { 
                          "include": "#name-in-context",
                          "comment": "I.e., class names, method names, property names, and variable names."
                        }
                    ]
                }
            }
        },
  
        "label-declaration": {
            "name": "meta.function.label.psl",
            "comment": "---",
            "comment": "A label declaration is a method declaration without a formal parameter list. Like a method,",
            "comment": "it starts in the first position of the line, but there are fewer variations that we need to",
            "comment": "account for. In its most extensive form it only has the following components:",
            "comment": "---",
            "comment": "* [accessModifier] labelName",
            "comment": "---",
            "comment": "However, the following scenario also needs to be recognized [DOES IT ?]:",
            "comment": "[Note that, as with method declarations, statements placed in the same line as the label",
            "comment": "declaration should not be recognized as one of its components; every statement to the right",
            "comment": "of the label declaration is considered to be (at least, part of) its body. Additionally, note",
            "comment": "that the same reasoning does not apply to 'if-directive' specified above: everything to the",
            "comment": "right of the token signalling the directive is actually part of it.]",
            "comment": "---",
            "comment": "* labelName [statement(s)]",
            "comment": "---",
            "comment": "Only visibility/scope modifiers are allowed in label declarations.",
            "comment": "---",
            "match": "^((public|protected|private)[ \t]+)?([%A-Za-z0-9][A-Za-z0-9]*)",
            "captures": {
                "2": { "name": "storage.modifier.visibility.psl", "comment": "Access modifiers."},
                "3": { "name": "entity.name.function.psl", "comment": "Label followed by statement."}
            }
        },
  
        "literals": {
            "patterns": [
                { 
                  "name": "constant.numeric.decimal.psl",
                  "comment": "Non-integer values.",
                  "match": "(?<=\\b|_)[0-9]*\\.[0-9]+(?=\\b|_)"
                },
                { 
                  "name": "constant.numeric.integer.psl",
                  "comment": "Integer values.",
                  "match": "(?<=\\b|_)[0-9]+(?=\\b|_)"
                },
                {
                  "include": "#strings",
                  "comment": "PSL String (double quoted)."
                }
            ]
        },
  
        "method-declaration": {
            "name": "meta.function.method.psl",
            "comment": "---",
            "comment": "A method declaration starts in the first position of the line. There are some variations that",
            "comment": "we need to account for. In its most extensive form it has the following components:",
            "comment": "---",
            "comment": "* [accessModifier ][storageModifier ]resultClass methodName ([formal-list])",
            "comment": "* [storageModifier ][accessModifier ]resultClass methodName ([formal-list])",
            "comment": "---",
            "comment": "From a syntax highlighting perspective, only the 'resultClass' and 'methodName' components of",
            "comment": "the construct are required.",
            "comment": "---",
            "comment": "May repetition of groups 1 and 3 be avoided?",
            "comment": "Replacing '(([a-z]+)[ \t]+)?(([a-z]+)[ \t]+)?' for '(([a-z]+)[ \t]+){0,2}' solely matches the",
            "comment": "second modifier. Repeating a captured group only captures the last iteration. Capturing a",
            "comment": "repeated group captures all iterations.",
            "comment": "---",
            "begin": "^(([a-z]+)[ \t]+)?(([a-z]+)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)\\(",
            "beginCaptures": {
                "2": { "patterns": [ { "include": "#modifiers", "comment": "Access modifier."}]},
                "4": { "patterns": [ { "include": "#modifiers", "comment": "Access modifier."}]},
                "5": { "patterns": [ { "include": "#class-names"}]},
                "6": { "name": "entity.name.function.psl"}
            },
            "end": "\\)",
            "patterns": [
                { "include": "#formal-parameter"},
                { "include": "#comments-inline-m"},
                { "include": "#comments-inline-psl"},
                { "include": "#comments-block"}
            ]
        },
  
        "modifiers": {
            "patterns": [
                { 
                  "name": "storage.modifier.psl",
                  "comment": "Storage modifiers [not valid in the context of SCM subroutine definition].",
                  "match": "\\b(final|literal|readonly|static)\\b"
                },
                { 
                  "name": "storage.modifier.visibility.psl",
                  "comment": "Visibility modifiers.",
                  "match": "\\b(public|protected|private)\\b"
                }
            ]
        },
  
        "name-in-context": {
            "comment": "Try to guess the kind of 'name' based on the surrounding characters.",
            "patterns": [
                { 
                  "name": "entity.name.function.psl",
                  "comment": "$$[name][^] ==> method name [followed by 'entity.name.class.psl' if non-local]",
                  "match": "\\$\\$([%A-Za-z][A-Za-z0-9]*)?(?=\\^?)"
                },
                { 
                  "name": "support.function.psl",
                  "comment": "$select( ==> M intrinsic function",
                  "match": "\\$select(?=\\()"
                },
                { 
                  "name": "storage.modifier.actual-list.psl",
                  "comment": "---",
                  "comment": "Literal dot signalling pass-by-return in actual parameter list. [Note that this must",
                  "comment": "precede both the ckecks for methods and properties.]",
                  "comment": "---",
                  "match": "(?<=\\B)(?<=[ \t\\(\\,])\\.(?=[%\"A-Za-z0-9][A-Za-z0-9]*)"
                },
                { 
                  "name": "entity.name.function.psl",
                  "comment": ".name( ==> a method name [or tree property]",
                  "match": "\\.[%A-Za-z][A-Za-z0-9]*(?=\\()"
                },
                { 
                  "name": "variable.other.propertydef.psl",
                  "comment": ".name ==> a property name [note that this must follow the check for methods]",
                  "match": "\\.[%A-Za-z][A-Za-z0-9]*"
                },
                { 
                  "name": "entity.name.class.psl",
                  "comment": "^name ==> class name",
                  "match": "\\^[%A-Za-z][A-Za-z0-9]*"
                },
                { 
                  "comment": "---",
                  "comment": "PSL language classes are usually valid in any context. They take precedence over static",
                  "comment": "method invocation and property reference [see below]. [Note that only 'native' PSL",
                  "comment": "classes are included here. Custom / user-defined classes that descend from any 'native'",
                  "comment": "class are recognized as such only if explicitly specified as part of a construct. That",
                  "comment": "is, constructs abstracted by the same regex pattern as a PSL language class descendent",
                  "comment": "(e.g., 'variable.other.psl') invariably get recognized by the syntax highlighter instead",
                  "comment": "of the latter.]",
                  "comment": "---",
                  "include": "#psl-language-class"
                },
                { 
                  "name": "variable.other.instanceOrStatic.psl",
                  "comment": "---",
                  "comment": "name. ==> instance variable [or class name in case of static method or property]",
                  "comment": "Look ahead positive for dot [i.e, '(?=\\.)'], since it already belongs to the scopes",
                  "comment": "'entity.name.function.psl' and 'variable.other.propertydef.psl'.",
                  "comment": "---",
                  "match": "[%A-Za-z][A-Za-z0-9]*(?=\\.)"
                },
                { 
                  "name": "entity.name.function.psl",
                  "comment": "---",
                  "comment": "name^ ==> method name [followed by 'entity.name.class.psl' if non-local]",
                  "comment": "Look ahead positive [non-capturing group] for caret [i.e, '(?=\\^)'], since it already",
                  "comment": "belongs to the scope 'entity.name.class.psl' [i.e., ^CLASS].",
                  "comment": "---",
                  "match": "[%A-Za-z][A-Za-z0-9]*(?=\\^)"
                },
                { 
                  "name": "storage.modifier.actual-list.psl",
                  "comment": "Keyword 'ret' in actual parameter list.",
                  "match": "\\b(ret)\\b"
                },
                { 
                  "name": "entity.name.function.psl",
                  "comment": "---",
                  "comment": "do name[(], ... ==> invocation of local label/subroutine",
                  "comment": "---",
                  "comment": "Bear in mind that, currently, only the first occurrence of a label/subroutine gets",
                  "comment": "recognized by the highlighter.",
                  "comment": "---",
                  "match": "(?<=do )[%A-Za-z][A-Za-z0-9]*(?=\\(?)"
                },
                { 
                  "name": "variable.other.psl",
                  "comment": "Local variables [either declared ot not] or 'non-native' PSL classes.",
                  "match": "[%A-Za-z][A-Za-z0-9]*"
                },
                { 
                  "name": "entity.name.unknown.psl",
                  "comment": "If nothing else matches, try if it is a PSL/M name [currently, ineffectual].",
                  "match": "[%A-Z-a-z][A-Z-a-z0-9]*"
                }
            ]
        },
  
        "operators": {
            "name": "keyword.operator.psl",
            "comment": "Unary and binary operators.",
            "match": "\\@|\\:|\\_|\\+|\\-|\\*|\\/|\\\\|\\#|\\<|\\=|\\>|\\!|\\&|\\?|\\'|(\\b(or|and|not)\\b)"
        },
  
        "optimize-directive": {
            "comment": "#OPTIMIZE directive.",
            "match": "^[ \t]+(#OPTIMIZE)\\b(.*)?",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.optimize.psl"},
                "2": {
                    "patterns": [
                        { "include": "#optimize-keywords"},
                        { "name": "constant.language.psl", "match": "\\b(ON|OFF)\\b"}
                    ]
                }
            }
        },
  
        "optimize-keywords": {
            "comment": "Active and deprecated OPTIMIZE keywords",
            "patterns": [
                { "name": "keyword.other.optimize.psl", "match": "\\b(CUVARLITERAL|OBJECTS)\\b"},
                { "name": "invalid.keyword.other.optimize.psl", "match": "\\b(FUNCTIONS)\\b"}
            ]
        },
  
        "option-directive": {
            "comment": "#OPTION directive.",
            "match": "^[ \t]+(#OPTION)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.option.psl"},
                "2": {
                    "patterns": [
                        { "include": "#option-keywords"},
                        { "name": "constant.language.psl", "match": "\\b(ON|OFF)\\b"}
                    ]
                }
            }
        },
  
        "option-keywords": {
            "comment": "Active and deprecated/ignored #OPTION keywords.",
            "patterns": [
                { 
                  "name": "keyword.other.option-keyword.psl",
                  "match": "\\b(IncludePSL|ResultClass)\\b"
                },
                { 
                  "name": "invalid.keyword.other.option-keyword.psl",
                  "match": "(\\B\\$GetEFD|\\b(AutoPublicERRM|nolink))\\b"
                }
            ]
        },
  
        "other-directive": {
            "comment": "---",
            "comment": "PSL code generator directives that stand alone. All text following the directive is ignored",
            "comment": "(i.e., treated as comment).",
            "comment": "---",
            "match": "^[ \t]+(#BYPASS|#ELSE|#END|#ENDBYPASS|#ENDIF)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.psl"},
                "2": { "name": "comment.inline.psl"}
            }
        },
  
        "package-directive": {
            "comment": "---",
            "comment": "#PACKAGE directive, followed by root package and (optionally) subpackages",
            "comment": "---",
            "comment": "Grouping the whole expression following the directive token [i.e., '#PACKAGE'] as optional,",
            "comment": "allows for the latter to be recognized by the highlighter even if no text [including spaces]",
            "comment": "immediately follows it. Although it is syntactically incorrect to utilize '#PACKAGE' in a",
            "comment": "freestanding fashion, from a syntax highlighting perspective, it makes sense for it to be",
            "comment": "promptly recognized as it is written.",
            "comment": "---",
            "match": "^[ \t]+(#PACKAGE)\\b([ \t]+([A-Za-z][A-Za-z0-9]*)((?:\\.)([A-Za-z][A-Za-z0-9]*))*)?",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.package.psl"},
                "3": { "name": "entity.name.rootPackage.psl"},
                "5": { "name": "entity.name.subPackage.psl"}
            }
        },
  
        "propertydef-directive": {
            "comment": "---",
            "comment": "Visit the 'package-directive' subsection for the reasoning behing the optional group at the",
            "comment": "end of the regex.",
            "comment": "---",
            "match": "^[ \t]+(#PROPERTYDEF)\\b(([ \t]+([%A-Za-z][A-Za-z0-9]*))(.*))?",
            "captures": {
                "1": { "name": "constant.language.propertydef.psl"},
                "4": { "name": "entity.name.other.property.psl"},
                "5": {
                    "patterns": [
                        {"name": "keyword.other.propertydef.psl", "match": "\\b(class|description|node|position)\\b"},
                        { "include": "#modifiers"},
                        { "include": "#special-constructs"},
                        { "include": "#literals"},
                        { "include": "#class-names"},
                        { "include": "#operators"}
                    ]
                }
            }
        },
  
        "psl-language-class": {
            "name": "support.class.language.psl",
            "comment": "---",
            "comment": "Keyword 'void', PSL Language classes, and Record descendants.",
            "comment": "---",
            "comment": "[NOTE: Do not remove the underscore from both look-behind and look-ahead non-capturing groups.",
            "comment": "The underscores are included to account for cases where strings or string-convertible objects",
            "comment": "are yielded via either invoking a static method or referencing a literal property of a given",
            "comment": "class, and a concatenation operation precedes or follows the expression.]",
            "comment": "---",
            "match": "(?<=\\b|_)(void|Boolean|ByteString|Class|Column|Date|Db|DbSet|Error|Host|Integer|IO|List|Number|Object|Primitive|PSL|PslColumnChange|PslJsonObject|Reference|ResultSet|Row|RowSet|Runtime|String|Time|DbsMakerCheckerDlgt|FwkAuthenticate|FwkHostSTF|FwkRestriction|FwkRestrictionOvr|PslDateDlgt|PslMapDlgt|PslMapPathsDlgt|PslNumberDlgt|DBARCHIVE|DbsFunc|DbsFuncUcls|DbsValueDescriptions|FwkErrorLogger|FwkErrorLogReport|FwkEvent|FwkInstCompile|FwkInstTypeInterface|FwkMessage|FwkNotification|FwkStringUtil|PbsPjiCore|PbsPjiProxyVerify|PslMap|PslMapPaths|PslUtAssert|PslUtTestCase|PslUtTestCase4Pbs|PslUtTestSuite|PslUtTestResult|PslUtPbsInterface|Record[A-Za-z0-9]*)(?=\\b|_)"
        },
  
        "special-constructs": {
            "patterns": [
                {
                  "name": "constant.language.psl",
                  "match": "(?<=\\b|_)(true|false)(?=\\b|_)"
                },
                {
                  "name": "constant.language.systemkeyword.psl", 
                  "comment": "System keywords that are constant within the PSL process.",
                  "match": "(?<=\\B|_)(%ModuleName|%ProcessID|%UserDirectory|%UserName)(?=\\b|_)"
                },
                {
                  "name": "variable.language.systemkeyword.readonly.psl",
                  "comment": "System keywords that are variable within the PSL process but read-only.",
                  "match": "(?<=\\B|_)(%CurrentDate|%CurrentTime)(?=\\b|_)"
                },
                {
                  "name": "variable.language.systemkeyword.readwrite.psl",  
                  "comment": "System keywords that are variable within the PSL process.",
                  "match": "(?<=\\B|_)(%BatchExit|%BatchRestart|%CompanyName|%EffectiveDate|%Identifier|%ProcessMode|%SessionID|%SystemCurrency|%SystemDate|%UserClass|%UserID|%UserStation)(?=\\b|_)"
                },
                {
                  "name": "variable.language.psl",
                  "match": "(?<=\\b|_)(this|super)(?=\\b|_)"
                }
            ]
        },
  
        "statements": {
            "patterns": [
                {
                  "comment": "Declaration statement - 'type static <className>'",
                  "match": "(type)[ \t]+(static)[ \t]+([%A-Za-z][A-Za-z0-9]*)",
                  "captures": {
                      "1": { "name": "keyword.other.declaration.static"},
                      "2": { "name": "storage.modifier.scope.psl"},
                      "3": { "patterns": [ { "include": "#class-names"}]}
                  }
                },
                {
                  "comment": "---",
                  "comment": "Declaration statement - tree",
                  "comment": "---",
                  "comment": " 1. keyword 'type'",
                  "comment": " 2. modifiers 'public new' and 'public' [optional]",
                  "comment": "    [note that 'public new' must occur before 'public'; otherwise, if the modifier",
                  "comment": "    'public new' is used, 'new' will be taken as a class name]",
                  "comment": " 3. <className>",
                  "comment": " 4. <variableName>",
                  "comment": " 5. (<className>, ...)",
                  "comment": "---",
                  "match": "(type)[ \t]+((public[ \t]+new|public)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)(\\(([ \t]*([%A-Za-z][A-Za-z0-9]*)\\,?)*\\))",
                  "captures": {
                      "1": { "name": "keyword.other.declaration.tree"},
                      "3": { "name": "storage.modifier.scope.psl"},
                      "4": { "patterns": [ { "include": "#class-names"}]},
                      "5": { "name": "variable.other.psl"},
                      "6": { "patterns": [ { "include": "#class-names"} ]}
                  }
                },
                {
                  "comment": "---",
                  "comment": "Declaration statement - deprecated tree",
                  "comment": "---",
                  "comment": " 1. keyword 'type'",
                  "comment": " 2. modifiers 'public new', 'public' and 'literal'",
                  "comment": " 3. class name",
                  "comment": " 4. variable name",
                  "comment": " 5. (, ...)",
                  "comment": "---",
                  "comment": "A tree declaration is considered to be deprecated if it includes the modifier 'literal'",
                  "comment": "or there is no type specification at any level of the tree. [Note that only the commas",
                  "comment": "separating levels in the tree reference are highlighted in red.]",
                  "comment": "---",
                  "match": "(type)[ \t]+((public[ \t]+new|public|literal)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)(\\(([ \t]*\\,+[ \t]*)*\\))",
                  "captures": {
                      "1": { "name": "keyword.other.declaration.deprecated"},
                      "3": { "name": "storage.modifier.scope.psl"},
                      "4": { "patterns": [ { "include": "#class-names"}]},
                      "5": { "name": "variable.other.psl"},
                      "6": { "name": "invalid.deprecated.tree.psl"}
                  }
                },
                {
                  "comment": "---",
                  "comment": "Declaration statement - illegal tree",
                  "comment": "---",
                  "comment": " 1. keyword 'type'",
                  "comment": " 2. modifiers 'public new', 'public' and 'literal'",
                  "comment": " 3. class name",
                  "comment": " 4. variable name",
                  "comment": " 5. [e.g.] ( ,, <className>, <className>, ...)",
                  "comment": "---",
                  "comment": "A tree declaration is considered to be illegal if at least one but not all types is/are",
                  "comment": "specified at each level of the tree reference. [See that the whole parenthesized portion",
                  "comment": "of the tree reference receives red coloration.]",
                  "comment": "---",
                  "match": "(type)[ \t]+((public[ \t]+new|public|literal)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)(\\(([ \t]*([%A-Za-z][A-Za-z0-9]*)?\\,?)*\\))",
                  "captures": {
                      "1": { "name": "keyword.other.declaration.illegal"},
                      "3": { "name": "storage.modifier.scope.psl"},
                      "4": { "patterns": [ { "include": "#class-names"}]},
                      "5": { "name": "variable.other.psl"},
                      "6": { "name": "invalid.illegal.tree.psl"}
                  }
                },
                { 
                  "comment": "---",  
                  "comment": "Declaration statement - other",
                  "comment": "---",
                  "comment": " 1. keyword 'type'",
                  "comment": " 2. modifiers 'public new', 'public', and 'literal'",
                  "comment": " 3. <className>",
                  "comment": " 4. <variableName>",
                  "comment": " 5. <, variable name ...>",
                  "comment": "---",
                  "match": "(type)[ \t]+((public[ \t]+new|public|literal)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)[ \t]+([%A-Za-z][A-Za-z0-9]*)(([ \t]*\\,[ \t]*[%A-Za-z][A-Za-z0-9]*)*)",
                  "captures": {
                      "1": { "name": "keyword.other.declaration.other"},
                      "3": { "name": "storage.modifier.scope.psl"},
                      "4": { "patterns": [ { "include": "#class-names"}]},
                      "5": { "name": "variable.other.psl"},
                      "6": { "patterns": [{ "name": "variable.other.psl", "match": "[%A-Za-z][A-Za-z0-9]*"}]}
                  }
                },
                { 
                  "comment": "Deprecated statements",
                  "patterns": [
                      { 
                        "name": "invalid.deprecated.statement.psl", 
                        "match": "\\b(?<!\\.)(close|open|read|use)\\b"
                      },
                      {
                        "name": "invalid.deprecated.statement.quit.psl",
                        "comment": "---",
                        "comment": "'quit' statement followed by non-whitespace characters [\\S+] except for comment",
                        "comment": "initializers [either \\/ or \\;]. [Note that it supports post-conditionalization,",
                        "comment": "although post-conditional expressions with more than one level of nesting do not",
                        "comment": "get recognized as such. E.g., the expression 'quit:(a or b) foo' is identified as",
                        "comment": "deprecated, whilst the expression 'quit:(a or (b and c)) foo' is not. Also, bear",
                        "comment": "in mind that the 'ALTERmatch' below, although simpler and more concise, does not",
                        "comment": "support parenthesized expressions in post-conditionals.]",
                        "comment": "---",
                        "ALTERmatch": "\\b(?<!\\.)quit(?=(\\:\\S*)? (?![\\/\\;])(?=\\S+))",
                        "match": "\\b(?<!\\.)quit(?=(\\:([^\\(\n]*|\\([ \t%A-Za-z0-9]*\\)))? (?![\\/\\;])(?=\\S+))"
                      }
                  ]
                },
                {
                  "name": "keyword.control.statement.psl",
                  "comment": "Control statements",
                  "match": "\\b(?<!\\.)(catch|do|else|for|if|job|quit|return|throw|while)\\b"
                },
                { 
                  "name": "keyword.other.statement.psl",
                  "comment": "---",
                  "comment": "Other statements",
                  "comment": "---",
                  "comment": "Mind that the statement 'write' is obsolete only in the context of writing to files. In",
                  "comment": "PSL, there is no other way for outputing text to the screen.",
                  "comment": "---",
                  "match": "\\b(?<!\\.)(halt|hang|kill|lock|set|type|unlock|write)\\b"
                }
            ]
        },
  
        "strings": {
            "name": "string.quoted.double.psl",
            "begin": "\"",
            "end": "\""
        },
  
        "subroutine-declaration": {
            "name": "meta.function.subroutine.psl",
            "comment": "---",
            "comment": "A subroutine declaration starts in the first position of the line. There are some variations",
            "comment": "that we need to account for. In its most extensive form it has the following components:",
            "comment": "---",
            "comment": "* [accessModifier ][className ]subroutineName([formal-list])",
            "comment": "",
            "comment": "Solely the 'subroutineName' is required. Moreover, only visibility/scope modifiers (that is,",
            "comment": "the modifiers 'public', 'protected' and 'private') are allowed in subroutine declarations.",
            "comment": "---",
            "begin": "^((public|protected|private)[ \t]+)?([%A-Za-z][A-Za-z0-9]*)\\(",
            "beginCaptures": {
                "2": { "name": "storage.modifier.visibility.psl", "comment": "Access modifiers."},
                "3": { "name": "entity.name.function.psl"}
            },
            "end": "\\)",
            "patterns": [
                { "include": "#formal-parameter"},
                { "include": "#comments-inline-m"},
                { "include": "#comments-inline-psl"},
                { "include": "#comments-block"}
            ]
        },
        
        "todo": {
            "name": "variable.other.jsdoc",
            "comment": "---",
            "comment": "'TODO' solely has significance in the context of comments [either single-line or blocks].",
            "comment": "Hence, there is no need for including comment initializers in the 'begin' construct. Moreover,",
            "comment": "note that a 'TODO' expression may end with both comment initializers and finalizers.",
            "comment": "---",
            "begin": "\\bTODO\\b",
            "end": "(?=\\n|\\*/|/\\*|//)",
            "patterns": [ { "name": "storage.type.class.jsdoc", "match": "@\\w+"}]
        },
        
        "warn-directive": {
            "comment": "#WARN and #INFO directives",
            "match": "^[ \t]+(#INFO|#WARN)\\b(.*)",
            "captures": {
                "1": { "name": "constant.language.codeGeneratorDirective.psl"},
                "2": {
                    "patterns": [
                        {"include": "#warn-group"},
                        {"name": "constant.language.psl", "match": "\\b(ON|OFF)\\b"}
                    ]
                }
            }
        },
  
        "warn-group": {
            "comment": "#WARN, #INFO and #ACCEPT groups.",
            "patterns": [
                {
                  "name": "keyword.other.warnGroup.psl",
                  "match": "\\b(ACCESS|BYPASS|DATABASE|DEAD|DEPRECATED|FUNCTION|GLOBAL|LENGTH|MISMATCH|PRECEDENCE|READ|RECEXISTS|SCOPE|SYNTAX|SYSVAR)\\b"
                },
                { 
                  "name": "invalid.keyword.warnGroup.security.psl",
                  "match": "\\b(DYNAMIC|XECUTE)\\b"
                }
            ]
        }
    }
  }
  