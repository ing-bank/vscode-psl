{
    "compilerOptions": {
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "target": "esnext",
        "outDir": "out",
        "esModuleInterop": true,
        "lib": [
            "esnext"
        ],
        "inlineSourceMap": true,
        "rootDir": ".",
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true
    },
    "exclude": [
        "node_modules"
    ]
}
